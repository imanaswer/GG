# ── Core Auth ─────────────────────────────────────────────────────────────────
AUTH_SECRET="your-random-32-char-secret-here"           # openssl rand -base64 32

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://gridgame.in"               # or http://localhost:3000

# ── Claude AI ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."                          # Powers AI recommendations

# ── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
# Pooled connection (via PgBouncer) — used by the running app at request time.
# Supabase → Project Settings → Database → Connection string → "Transaction" pooler.
DATABASE_URL="postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection — used by `prisma migrate` which needs a non-pooled socket.
# Supabase → Project Settings → Database → Connection string → "Direct connection".
DIRECT_URL="postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_..."                          # Public — safe for client
RAZORPAY_KEY_SECRET="..."                               # NEVER expose to client
RAZORPAY_WEBHOOK_SECRET="..."                           # For verifying webhook signatures

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."                                 # From resend.com
FROM_EMAIL="hello@gridgame.in"                          # Must be verified in Resend

# ── Images (Cloudinary) ───────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"    # Public — safe to expose
CLOUDINARY_API_KEY="..."                                # Server-side only
CLOUDINARY_API_SECRET="..."                             # NEVER expose to client

# ── Rate Limiting (Upstash Redis) ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://..."                    # From upstash.com
UPSTASH_REDIS_REST_TOKEN="..."                          # From upstash.com

# ── Error Monitoring (Sentry) — Optional but strongly recommended ──────────────
SENTRY_DSN="https://...@sentry.io/..."                 # From sentry.io

# ── Analytics (PostHog) — Optional ────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_..."                      # From posthog.com

# ── Maps — Optional ───────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY="AIza..."                  # For location picker

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD="..."                                    # Hashed password for admin dashboard

# ── Cron Security ─────────────────────────────────────────────────────────────
CRON_SECRET="..."                                       # Random string for cron auth
